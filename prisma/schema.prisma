// Prisma Schema для системы учета контейнерных автоперевозок (PostgreSQL для Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ПОЛЬЗОВАТЕЛИ И АУТЕНТИФИКАЦИЯ
// ============================================

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  password            String?   // Хэшированный пароль
  image               String?
  role                Role      @default(MANAGER)

  // Верификация
  emailVerified       DateTime?
  verificationToken   String?   @unique

  // Двухфакторная аутентификация
  isTwoFactorEnabled  Boolean   @default(false)
  twoFactorSecret     String?

  // Восстановление пароля
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?

  // Сессии и аккаунты (для NextAuth)
  accounts            Account[]
  sessions            Session[]

  // Связи
  orders              Order[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// РОЛИ ПОЛЬЗОВАТЕЛЕЙ
// ============================================

enum Role {
  ADMIN     // Администратор - полный доступ
  MANAGER   // Менеджер - ограниченный доступ
}

// ============================================
// ЗАЯВКИ НА ПЕРЕВОЗКУ
// ============================================

model Order {
  id                    String        @id @default(cuid())
  orderNumber           String        @unique  // Автоматически генерируемый номер

  // Место загрузки
  loadingDatetime       DateTime
  loadingCity           String
  loadingAddress        String

  // Место выгрузки
  unloadingCity         String
  unloadingAddress      String

  // Информация о контейнере и грузе
  containerNumber       String
  containerTypeId       String
  containerType         ContainerType @relation(fields: [containerTypeId], references: [id])
  cargoWeight           Float         // Вес в тоннах

  // Статус
  status                OrderStatus   @default(NEW)

  // Водитель и транспорт
  driverId              String?
  driver                Driver?       @relation(fields: [driverId], references: [id])
  vehicleId             String?
  vehicle               Vehicle?      @relation(fields: [vehicleId], references: [id])

  // Создатель заявки
  userId                String
  user                  User          @relation(fields: [userId], references: [id])

  // Примечания
  notes                 String?       @db.Text

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

enum OrderStatus {
  NEW         // Новая
  IN_PROGRESS // В пути
  DELIVERED   // Доставлена
  CANCELLED   // Отменена
}

// ============================================
// СПРАВОЧНИКИ
// ============================================

// Водители
model Driver {
  id              String    @id @default(cuid())
  fullName        String    // ФИО
  phone           String?
  licenseNumber   String?
  passportData    String?   @db.Text
  isActive        Boolean   @default(true)

  // Связи
  orders          Order[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Транспортные средства
model Vehicle {
  id              String      @id @default(cuid())
  vehicleNumber   String      // Госномер автомобиля
  trailerNumber   String?
  brand           String?
  vehicleType     String?
  isActive        Boolean     @default(true)

  // Связи
  orders          Order[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// Типы контейнеров
model ContainerType {
  id              String    @id @default(cuid())
  name            String    // Название (20 футов, 40 футов, рефрижератор)
  code            String?
  description     String?   @db.Text
  isActive        Boolean   @default(true)

  // Связи
  orders          Order[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// ЛОГИРОВАНИЕ ДЕЙСТВИЙ (Аудит)
// ============================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  details     String?     @db.Text
  ipAddress   String?
  userAgent   String?     @db.Text
  createdAt   DateTime    @default(now())
}
